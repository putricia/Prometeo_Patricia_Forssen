<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="stage" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.logitronapp.MainController">
   <top>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Acceso de usuarios" BorderPane.alignment="CENTER">
         <font>
            <Font name="Arial" size="29.0" />
         </font>
         <BorderPane.margin>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </BorderPane.margin>
      </Text>
   </top>
   <center>
      <VBox fx:id="vBox" alignment="CENTER" maxHeight="100.0" maxWidth="300.0" prefHeight="200.0" prefWidth="100.0" spacing="25.0" translateY="-20.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="editUsuario" promptText="Usuario" />
            <TextField fx:id="editClave" promptText="Contraseña" />
            <HBox fx:id="hBox" alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="60.0">
               <children>
                  <Button fx:id="btnAcceso" mnemonicParsing="false" text="Acceder" />
                  <Button fx:id="btnNuevaClave" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" text="Nueva contraseña" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </center>
   <bottom>
      <Text fx:id="txtFeedback" strokeType="OUTSIDE" strokeWidth="0.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="50.0" />
         </BorderPane.margin>
      </Text>
   </bottom>
</BorderPane>
